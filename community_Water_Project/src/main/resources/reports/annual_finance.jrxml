<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="annual_finance"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20">

  <parameter name="YEAR" class="java.lang.Integer"/>

  <queryString>
    <![CDATA[
      SELECT section, section_label, label, amount, sort_order
      FROM (

        SELECT
          '1_subscriptions'       AS section,
          'SUBSCRIPTION INCOME'   AS section_label,
          CONCAT(h.house_number, ' ', h.street_address, ' (', z.name, ')') AS label,
          COALESCE(SUM(sp.amount), 0) AS amount,
          1 AS sort_order
        FROM subscription s
        JOIN household h         ON h.id = s.household_id
        JOIN water_zone z        ON z.id = h.zone_id
        LEFT JOIN subscription_payment sp ON sp.subscription_id = s.id
        WHERE s.year = $P{YEAR}
        GROUP BY h.id, h.house_number, h.street_address, z.name

        UNION ALL

        SELECT
          '2_maintenance',
          'MAINTENANCE COSTS',
          CONCAT(mw.title, ' (', COALESCE(pt.name, wt.name), ')') AS label,
          COALESCE(SUM(mc.total_cost), 0),
          2
        FROM maintenance_work mw
        LEFT JOIN public_tap pt       ON pt.id  = mw.tap_id
        LEFT JOIN water_tank wt       ON wt.id  = mw.tank_id
        LEFT JOIN maintenance_cost mc ON mc.maintenance_work_id = mw.id
        WHERE YEAR(mw.work_date) = $P{YEAR}
        GROUP BY mw.id, mw.title, pt.name, wt.name

        UNION ALL

        SELECT
          '3_expenditures',
          'OTHER EXPENDITURES',
          CONCAT(e.description, ' (', ec.name, ')') AS label,
          e.amount,
          3
        FROM expenditure e
        JOIN expenditure_category ec ON ec.id = e.category_id
        WHERE YEAR(e.expenditure_date) = $P{YEAR}

        UNION ALL

        SELECT
          '4_committee',
          'COMMITTEE PAYMENTS',
          CONCAT(cm.first_name, ' ', cm.last_name, ' - ', cp.payment_type) AS label,
          cp.amount,
          4
        FROM committee_payment cp
        JOIN committee_member cmt ON cmt.id = cp.committee_member_id
        JOIN community_member cm  ON cm.id  = cmt.member_id
        WHERE YEAR(cp.payment_date) = $P{YEAR}

      ) combined
      ORDER BY sort_order, label
    ]]>
  </queryString>

  <field name="section"       class="java.lang.String"/>
  <field name="section_label" class="java.lang.String"/>
  <field name="label"         class="java.lang.String"/>
  <field name="amount"        class="java.math.BigDecimal"/>
  <field name="sort_order"    class="java.lang.Integer"/>

  <variable name="TOTAL_SUBSCRIPTIONS" class="java.math.BigDecimal" calculation="Sum">
    <variableExpression>
      <![CDATA[$F{section}.startsWith("1") ? $F{amount} : java.math.BigDecimal.ZERO]]>
    </variableExpression>
  </variable>
  <variable name="TOTAL_MAINTENANCE" class="java.math.BigDecimal" calculation="Sum">
    <variableExpression>
      <![CDATA[$F{section}.startsWith("2") ? $F{amount} : java.math.BigDecimal.ZERO]]>
    </variableExpression>
  </variable>
  <variable name="TOTAL_EXPENDITURES" class="java.math.BigDecimal" calculation="Sum">
    <variableExpression>
      <![CDATA[$F{section}.startsWith("3") ? $F{amount} : java.math.BigDecimal.ZERO]]>
    </variableExpression>
  </variable>
  <variable name="TOTAL_COMMITTEE" class="java.math.BigDecimal" calculation="Sum">
    <variableExpression>
      <![CDATA[$F{section}.startsWith("4") ? $F{amount} : java.math.BigDecimal.ZERO]]>
    </variableExpression>
  </variable>
  <variable name="SECTION_SUBTOTAL" class="java.math.BigDecimal"
            resetType="Group" resetGroup="SectionGroup" calculation="Sum">
    <variableExpression><![CDATA[$F{amount}]]></variableExpression>
  </variable>

  <!-- Group by section -->
  <group name="SectionGroup">
    <groupExpression><![CDATA[$F{section}]]></groupExpression>

    <!-- Section header band -->
    <groupHeader>
      <band height="28">
        <rectangle>
          <reportElement x="0" y="4" width="535" height="20"
                         backcolor="#2E4057" mode="Opaque"/>
        </rectangle>
        <textField>
          <reportElement x="5" y="4" width="400" height="20" forecolor="#FFFFFF"/>
          <textElement>
            <font size="10" isBold="true"/>
          </textElement>
          <textFieldExpression><![CDATA[$F{section_label}]]></textFieldExpression>
        </textField>
        <staticText>
          <reportElement x="400" y="4" width="130" height="20" forecolor="#FFFFFF"/>
          <textElement textAlignment="Right">
            <font size="9" isBold="true"/>
          </textElement>
          <text><![CDATA[AMOUNT (FCFA)]]></text>
        </staticText>
      </band>
    </groupHeader>

    <!-- Section footer — subtotal per section -->
    <groupFooter>
      <band height="22">
        <line>
          <reportElement x="0" y="0" width="535" height="1"/>
          <graphicElement><pen lineWidth="0.5" lineStyle="Dashed"/></graphicElement>
        </line>
        <textField>
          <reportElement x="0" y="3" width="400" height="16"/>
          <textElement>
            <font size="9" isBold="true" isItalic="true"/>
          </textElement>
          <textFieldExpression>
            <![CDATA["Subtotal - " + $F{section_label}]]>
          </textFieldExpression>
        </textField>
        <textField>
          <reportElement x="400" y="3" width="135" height="16"/>
          <textElement textAlignment="Right">
            <font size="9" isBold="true"/>
          </textElement>
          <textFieldExpression>
            <![CDATA[String.format("%,.2f", $V{SECTION_SUBTOTAL})]]>
          </textFieldExpression>
        </textField>
      </band>
    </groupFooter>
  </group>

  <!-- ==================== TITLE ==================== -->
  <title>
    <band height="90">
      <staticText>
        <reportElement x="0" y="0" width="535" height="35"/>
        <textElement textAlignment="Center">
          <font size="20" isBold="true"/>
        </textElement>
        <text><![CDATA[AquaCam Connect]]></text>
      </staticText>
      <textField>
        <reportElement x="0" y="35" width="535" height="28"/>
        <textElement textAlignment="Center">
          <font size="14" isBold="true"/>
        </textElement>
        <textFieldExpression>
          <![CDATA["Annual Financial Report - " + $P{YEAR}]]>
        </textFieldExpression>
      </textField>
      <textField>
        <reportElement x="0" y="63" width="535" height="18"/>
        <textElement textAlignment="Center">
          <font size="9"/>
        </textElement>
        <textFieldExpression>
          <![CDATA["Generated on: " + new java.util.Date().toString()]]>
        </textFieldExpression>
      </textField>
    </band>
  </title>

  <pageHeader>
    <band height="0"/>
  </pageHeader>

  <columnHeader>
    <band height="0"/>
  </columnHeader>

  <!-- ==================== DETAIL ROWS ==================== -->
  <detail>
    <band height="18">
      <textField isBlankWhenNull="true">
        <reportElement x="10" y="0" width="390" height="18"/>
        <textElement>
          <font size="9"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{label}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="400" y="0" width="135" height="18"/>
        <textElement textAlignment="Right">
          <font size="9"/>
        </textElement>
        <textFieldExpression>
          <![CDATA[String.format("%,.2f", $F{amount})]]>
        </textFieldExpression>
      </textField>
    </band>
  </detail>

  <columnFooter>
    <band height="0"/>
  </columnFooter>

  <!-- ==================== PAGE FOOTER ==================== -->
  <pageFooter>
    <band height="25">
      <staticText>
        <reportElement x="0" y="3" width="300" height="16"/>
        <textElement><font size="8"/></textElement>
        <text><![CDATA[AquaCam Connect - Water Management System]]></text>
      </staticText>
      <textField>
        <reportElement x="435" y="3" width="100" height="16"/>
        <textElement textAlignment="Right"><font size="8"/></textElement>
        <textFieldExpression>
          <![CDATA["Page " + $V{PAGE_NUMBER}]]>
        </textFieldExpression>
      </textField>
    </band>
  </pageFooter>

  <!-- ==================== SUMMARY ==================== -->
  <summary>
    <band height="220">

      <line>
        <reportElement x="0" y="10" width="535" height="1"/>
        <graphicElement><pen lineWidth="1.0"/></graphicElement>
      </line>

      <!-- Summary title -->
      <staticText>
        <reportElement x="0" y="18" width="535" height="22"/>
        <textElement textAlignment="Center">
          <font size="13" isBold="true"/>
        </textElement>
        <text><![CDATA[FINANCIAL SUMMARY]]></text>
      </staticText>

      <!-- Total Income -->
      <staticText>
        <reportElement x="0" y="48" width="350" height="20"/>
        <textElement><font size="11" isBold="true"/></textElement>
        <text><![CDATA[Total Subscription Income:]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="48" width="185" height="20"/>
        <textElement textAlignment="Right"><font size="11"/></textElement>
        <textFieldExpression>
          <![CDATA[String.format("FCFA %,.2f", $V{TOTAL_SUBSCRIPTIONS})]]>
        </textFieldExpression>
      </textField>

      <!-- Maintenance -->
      <staticText>
        <reportElement x="0" y="72" width="350" height="20"/>
        <textElement><font size="11" isBold="true"/></textElement>
        <text><![CDATA[Total Maintenance Costs:]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="72" width="185" height="20"/>
        <textElement textAlignment="Right"><font size="11"/></textElement>
        <textFieldExpression>
          <![CDATA[String.format("FCFA %,.2f", $V{TOTAL_MAINTENANCE})]]>
        </textFieldExpression>
      </textField>

      <!-- Expenditures -->
      <staticText>
        <reportElement x="0" y="96" width="350" height="20"/>
        <textElement><font size="11" isBold="true"/></textElement>
        <text><![CDATA[Total Other Expenditures:]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="96" width="185" height="20"/>
        <textElement textAlignment="Right"><font size="11"/></textElement>
        <textFieldExpression>
          <![CDATA[String.format("FCFA %,.2f", $V{TOTAL_EXPENDITURES})]]>
        </textFieldExpression>
      </textField>

      <!-- Committee -->
      <staticText>
        <reportElement x="0" y="120" width="350" height="20"/>
        <textElement><font size="11" isBold="true"/></textElement>
        <text><![CDATA[Total Committee Payments:]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="120" width="185" height="20"/>
        <textElement textAlignment="Right"><font size="11"/></textElement>
        <textFieldExpression>
          <![CDATA[String.format("FCFA %,.2f", $V{TOTAL_COMMITTEE})]]>
        </textFieldExpression>
      </textField>

      <!-- Total Expenditure -->
      <line>
        <reportElement x="0" y="146" width="535" height="1"/>
        <graphicElement><pen lineWidth="0.5"/></graphicElement>
      </line>
      <staticText>
        <reportElement x="0" y="150" width="350" height="20"/>
        <textElement><font size="11" isBold="true"/></textElement>
        <text><![CDATA[Total Expenditure:]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="150" width="185" height="20"/>
        <textElement textAlignment="Right"><font size="11" isBold="true"/></textElement>
        <textFieldExpression>
          <![CDATA[String.format("FCFA %,.2f",
            $V{TOTAL_MAINTENANCE}
              .add($V{TOTAL_EXPENDITURES})
              .add($V{TOTAL_COMMITTEE}))]]>
        </textFieldExpression>
      </textField>

      <!-- Net Balance -->
      <line>
        <reportElement x="0" y="175" width="535" height="2"/>
        <graphicElement><pen lineWidth="2.0"/></graphicElement>
      </line>
      <staticText>
        <reportElement x="0" y="180" width="350" height="28"
                       backcolor="#D5F5E3" mode="Opaque"/>
        <textElement>
          <font size="13" isBold="true"/>
        </textElement>
        <text><![CDATA[  NET BALANCE:]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="180" width="185" height="28"
                       backcolor="#D5F5E3" mode="Opaque"/>
        <textElement textAlignment="Right">
          <font size="13" isBold="true"/>
        </textElement>
        <textFieldExpression>
          <![CDATA[String.format("FCFA %,.2f",
            $V{TOTAL_SUBSCRIPTIONS}
              .subtract($V{TOTAL_MAINTENANCE})
              .subtract($V{TOTAL_EXPENDITURES})
              .subtract($V{TOTAL_COMMITTEE}))]]>
        </textFieldExpression>
      </textField>

    </band>
  </summary>

</jasperReport>