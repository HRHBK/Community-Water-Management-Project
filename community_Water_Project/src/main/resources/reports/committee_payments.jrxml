<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="committee_payments"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20">

  <parameter name="YEAR" class="java.lang.Integer"/>

  <queryString>
    <![CDATA[
      SELECT
        CONCAT(cm.first_name, ' ', cm.last_name) AS member_name,
        cmt.role,
        cp.payment_type,
        cp.amount,
        cp.payment_date,
        cp.payment_method,
        cp.description
      FROM committee_payment cp
      JOIN committee_member cmt ON cmt.id = cp.committee_member_id
      JOIN community_member cm  ON cm.id  = cmt.member_id
      WHERE YEAR(cp.payment_date) = $P{YEAR}
      ORDER BY cp.payment_date DESC, cm.last_name
    ]]>
  </queryString>

  <field name="member_name"    class="java.lang.String"/>
  <field name="role"           class="java.lang.String"/>
  <field name="payment_type"   class="java.lang.String"/>
  <field name="amount"         class="java.math.BigDecimal"/>
  <field name="payment_date"   class="java.sql.Date"/>
  <field name="payment_method" class="java.lang.String"/>
  <field name="description"    class="java.lang.String"/>

  <variable name="TOTAL_PAID" class="java.math.BigDecimal" calculation="Sum">
    <variableExpression><![CDATA[$F{amount}]]></variableExpression>
  </variable>

  <title>
    <band height="80">
      <staticText>
        <reportElement x="0" y="0" width="535" height="35"/>
        <textElement textAlignment="Center">
          <font size="18" isBold="true"/>
        </textElement>
        <text><![CDATA[AquaCam Connect]]></text>
      </staticText>
      <textField>
        <reportElement x="0" y="35" width="535" height="25"/>
        <textElement textAlignment="Center">
          <font size="13" isBold="true"/>
        </textElement>
        <textFieldExpression>
          <![CDATA["Committee Payments Report - " + $P{YEAR}]]>
        </textFieldExpression>
      </textField>
      <textField>
        <reportElement x="0" y="60" width="535" height="20"/>
        <textElement textAlignment="Center"><font size="10"/></textElement>
        <textFieldExpression>
          <![CDATA["Generated on: " + new java.util.Date().toString()]]>
        </textFieldExpression>
      </textField>
    </band>
  </title>

  <pageHeader>
    <band height="0"/>
  </pageHeader>

  <columnHeader>
    <band height="25">
      <staticText>
        <reportElement x="0"   y="0" width="120" height="25" backcolor="#CCCCCC" mode="Opaque"/>
        <textElement><font isBold="true" size="9"/></textElement>
        <text><![CDATA[Member]]></text>
      </staticText>
      <staticText>
        <reportElement x="120" y="0" width="90"  height="25" backcolor="#CCCCCC" mode="Opaque"/>
        <textElement><font isBold="true" size="9"/></textElement>
        <text><![CDATA[Role]]></text>
      </staticText>
      <staticText>
        <reportElement x="210" y="0" width="90"  height="25" backcolor="#CCCCCC" mode="Opaque"/>
        <textElement><font isBold="true" size="9"/></textElement>
        <text><![CDATA[Payment Type]]></text>
      </staticText>
      <staticText>
        <reportElement x="300" y="0" width="75"  height="25" backcolor="#CCCCCC" mode="Opaque"/>
        <textElement><font isBold="true" size="9"/></textElement>
        <text><![CDATA[Date]]></text>
      </staticText>
      <staticText>
        <reportElement x="375" y="0" width="80"  height="25" backcolor="#CCCCCC" mode="Opaque"/>
        <textElement><font isBold="true" size="9"/></textElement>
        <text><![CDATA[Method]]></text>
      </staticText>
      <staticText>
        <reportElement x="455" y="0" width="80"  height="25" backcolor="#CCCCCC" mode="Opaque"/>
        <textElement textAlignment="Right"><font isBold="true" size="9"/></textElement>
        <text><![CDATA[Amount (FCFA)]]></text>
      </staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="20">
      <textField>
        <reportElement x="0"   y="0" width="120" height="20"/>
        <textElement><font size="9"/></textElement>
        <textFieldExpression><![CDATA[$F{member_name}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="120" y="0" width="90"  height="20"/>
        <textElement><font size="9"/></textElement>
        <textFieldExpression><![CDATA[$F{role}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="210" y="0" width="90"  height="20"/>
        <textElement><font size="9"/></textElement>
        <textFieldExpression><![CDATA[$F{payment_type}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="300" y="0" width="75"  height="20"/>
        <textElement><font size="9"/></textElement>
        <textFieldExpression><![CDATA[$F{payment_date}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="375" y="0" width="80"  height="20"/>
        <textElement><font size="9"/></textElement>
        <textFieldExpression><![CDATA[$F{payment_method}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="455" y="0" width="80"  height="20"/>
        <textElement textAlignment="Right"><font size="9"/></textElement>
        <textFieldExpression>
          <![CDATA[String.format("%,.2f", $F{amount})]]>
        </textFieldExpression>
      </textField>
    </band>
  </detail>

  <columnFooter>
    <band height="0"/>
  </columnFooter>

  <pageFooter>
    <band height="30">
      <staticText>
        <reportElement x="0" y="5" width="300" height="20"/>
        <textElement><font size="9"/></textElement>
        <text><![CDATA[AquaCam Connect - Water Management System]]></text>
      </staticText>
      <textField>
        <reportElement x="435" y="5" width="100" height="20"/>
        <textElement textAlignment="Right"><font size="9"/></textElement>
        <textFieldExpression>
          <![CDATA["Page " + $V{PAGE_NUMBER}]]>
        </textFieldExpression>
      </textField>
    </band>
  </pageFooter>

  <summary>
    <band height="40">
      <line>
        <reportElement x="0" y="0" width="535" height="1"/>
        <graphicElement><pen lineWidth="1.0"/></graphicElement>
      </line>
      <staticText>
        <reportElement x="0" y="5" width="455" height="25"/>
        <textElement textAlignment="Right">
          <font size="11" isBold="true"/>
        </textElement>
        <text><![CDATA[TOTAL PAID TO COMMITTEE (FCFA):]]></text>
      </staticText>
      <textField>
        <reportElement x="455" y="5" width="80" height="25"/>
        <textElement textAlignment="Right">
          <font size="11" isBold="true"/>
        </textElement>
        <textFieldExpression>
          <![CDATA[String.format("%,.2f", $V{TOTAL_PAID})]]>
        </textFieldExpression>
      </textField>
    </band>
  </summary>

</jasperReport>
